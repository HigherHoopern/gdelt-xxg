# .env 示例文件

# 1. 数据库配置
# Dev 模式 (本地): 使用 127.0.0.1
# Prod 模式 (Docker): 使用 db (docker-compose 中的服务名)
DB_URL=postgresql+psycopg2://user:password@db/dgelt
DB_POOL_SIZE=20

# 2. GDELT 配置
GDELT_UPDATE_URL=http://data.gdeltproject.org/gdeltv2/lastupdate.txt

# 3. 大模型与 RAG 配置
# LLM Provider: siliconflow, kmxxg, etc.
LLM_PROVIDER=siliconflow

# LLM (用于回答与研判)
LLM_MODEL_NAME="deepseek-ai/DeepSeek-V3"
LLM_BASE_URL="https://api.siliconflow.cn/v1"
LLM_API_KEY="your_api_key_here"

# Embedding (用于向量化)
EMBED_MODEL_NAME="BAAI/bge-m3"
EMBED_BASE_URL="https://api.siliconflow.cn/v1"
EMBED_API_KEY="your_api_key_here"

# Reranker (用于重排序)
RERANKER_NAME="BAAI/bge-reranker-v2-m3"
RERANKER_BASE_URL="https://api.siliconflow.cn/v1"

# 4. 系统调度周期 (秒)
INGEST_INTERVAL=900
PROCESS_INTERVAL=600
PREDICT_INTERVAL=3600
